# ============================================
# INFERRA FRONTEND ENV (Vite) — copy to .env.local and fill in.
# These are PUBLIC (shipped to the browser). Never put provider/secret keys here.
# ============================================

# Firebase Web config — Firebase Console → Project Settings → Your apps (Web)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Region your Cloud Functions are deployed to (default us-central1)
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Razorpay plan ids (public — used to start checkout). Create these plans in the
# Razorpay Dashboard → Subscriptions → Plans, then paste the plan_id values.
VITE_RAZORPAY_PLAN_STARTER=plan_xxxxxxxxxxxx
VITE_RAZORPAY_PLAN_GROWTH=plan_xxxxxxxxxxxx
VITE_RAZORPAY_PLAN_ENTERPRISE=plan_xxxxxxxxxxxx

# App Check (recommended for production): reCAPTCHA v3 site key from
# Firebase Console → App Check. Pair with ENFORCE_APPCHECK=true in functions/.env.
VITE_APPCHECK_SITE_KEY=

# Monitoring (optional): errors are always logged to the console; set an ingest
# URL to also receive them as JSON beacons (Sentry tunnel, Cloud Function, …).
VITE_MONITORING_ENDPOINT=
VITE_RELEASE=
